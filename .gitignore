# Python
__pycache__/
*.py[cod]
.venv/
venv/
.ipynb_checkpoints/

# YOLO weights (downloaded on demand)
*.pt

# Collected data / outputs
data/
*.csv
*.mp4
*.jpg

# Dashboard runtime snapshots (anomalies + returning visitors). Keep the
# directory structure (via .gitkeep), drop the images and manifests.
# `**/` prefix so the rule still matches after the move to src/web/snapshots/.
**/web/snapshots/**/*.jpg
**/web/snapshots/**/*.json
!**/web/snapshots/**/.gitkeep

# Firebase secrets / local env - never commit
firebase-service-account.json
*serviceAccount*.json
*firebase-adminsdk*.json
*-firebase-*.json
**/web/firebase-config.js
# Firebase CLI project binding — copy .firebaserc.example to .firebaserc
.firebaserc
.env
.env.local
.env.*.local
