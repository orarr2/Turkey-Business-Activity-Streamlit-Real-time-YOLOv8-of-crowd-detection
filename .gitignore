# Python
__pycache__/
*.py[cod]
.venv/
venv/
.ipynb_checkpoints/

# Editor / IDE preferences
.vscode/
.idea/

# YOLO weights (downloaded on demand)
*.pt

# Collected data / outputs
data/
*.csv
*.mp4
*.jpg

# Dashboard runtime snapshots (anomalies + returning visitors). Keep the
# directory structure (via .gitkeep), drop the images and manifests.
# `**/` prefix so the rule still matches after the move to src/web/snapshots/.
**/web/snapshots/**/*.jpg
**/web/snapshots/**/*.json
!**/web/snapshots/**/.gitkeep

# Firebase secrets / local env - never commit.
# NOTE: web/firebase-config.js is NOT listed here — the Firebase Web SDK config
# (apiKey/projectId/etc.) is a public project identifier by design and is safe
# to commit. Firestore Rules + the Admin SDK service-account key below are what
# actually protect the database. See docs/firebase_setup.md.
firebase-service-account.json
*serviceAccount*.json
*firebase-adminsdk*.json
*-firebase-*.json
# Firebase CLI project binding — copy .firebaserc.example to .firebaserc
.firebaserc
.env
.env.local
.env.*.local
