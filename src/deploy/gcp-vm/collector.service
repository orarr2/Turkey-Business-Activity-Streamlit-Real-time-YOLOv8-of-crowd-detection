[Unit]
Description=Turkey Business Activity — footfall collector
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=__INSTALL_DIR__/src
Environment=PYTHONUNBUFFERED=1
Environment=FIREBASE_CREDENTIALS=__SA_PATH__
Environment=FIREBASE_STORAGE_BUCKET=__STORAGE_BUCKET__
ExecStart=__INSTALL_DIR__/src/.venv/bin/python -m app.collector --interval 40
# --interval 40s means 4 slots x 3 writes/round x 2160 rounds/day = ~25,920
# Firestore writes/day - just above the 20K/day free tier, ~$0.85/month on Blaze.
# At interval=20 it would be ~52K/day (~$1.70/month). Trade-off: half the writes,
# half the temporal resolution. The dashboard's per-tile mini chart still fills
# up cleanly and the anomaly z-score window (30 samples) covers ~20 min now.
Restart=always
RestartSec=15
# Memory sizing for the e2-micro (1 GB, Always Free) this project runs on:
# measured peak ~635 MB RSS at the default imgsz 960 with a 3-frame burst,
# so these caps hold with headroom while still protecting the host. If the
# journal ever shows reclaim throttling or oom-kill restarts (rounds taking
# minutes, dashboard numbers frozen between updates), add --imgsz 640 to
# ExecStart above - roughly half the inference memory, at the cost of
# small/distant-object recall.
MemoryHigh=700M
MemoryMax=850M
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
