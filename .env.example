# =============================================================================
# Turkey Business Activity — environment template
# =============================================================================
# Copy this file to `.env` (gitignored) and fill in YOUR OWN values.
#   cp .env.example .env
#
# Some variables are read directly by the Python collector (server-side).
# The FIREBASE_* values mirror what Firebase shows in:
#   Console -> Project settings -> Your apps -> Web app -> SDK setup.
# Paste those same values into `web/firebase-config.js` (also gitignored) for
# the in-browser dashboard.
# =============================================================================


# --- Firebase: server-side (used by app/collector.py --backend firebase) -----
# Absolute path to your Firebase Admin SDK service-account JSON file.
# Generate at: Firebase Console -> Project settings -> Service accounts ->
#              Generate new private key.
# Keep the JSON outside the repo (anywhere that matches *serviceAccount*.json
# stays gitignored by default).
FIREBASE_CREDENTIALS=


# --- Firebase: web SDK config (paste into web/firebase-config.js) ------------
# These values are read by the browser dashboard. The web API key is not, by
# Firebase's design, a true secret — its job is to identify the project on the
# public web and security comes from your Firestore rules. Still: treat as
# private if your project is private, and tighten rules before any public deploy.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=


# --- Collector defaults (optional overrides; CLI flags still take precedence) -
# Same names as the CLI flags of `python -m app.collector --help`.
YOLO_WEIGHTS=yolov8n.pt
YOLO_CONF=0.25
COLLECTOR_INTERVAL_SEC=15
REID_DB=data/reid.db
REID_THRESHOLD=0.92
